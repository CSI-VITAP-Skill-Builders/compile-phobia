{
  "version": 2,
  "buildCommand": "npm run build --prefix devsync-frontend",
  "outputDirectory": "devsync-frontend/dist",
  "framework": "vite",
  "env": {
    "VITE_API_BASE_URL": "@vite_api_base_url"
  },
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
